# Copy to .env and fill in real values. .env is gitignored.
# Mock defaults let the testbed import & run offline with the MockBackend.

# --- Local black-box serving (Ollama / LM Studio) ---
OLLAMA_HOST=http://localhost:11434
DEFAULT_LOCAL_MODEL=llama3.1:8b

# --- Commercial reference model (calibration vs. published results) ---
# OPENAI_API_KEY may point at OpenAI or any OpenAI-compatible endpoint.
OPENAI_API_KEY=mock-api-key-change-me
OPENAI_BASE_URL=https://api.openai.com/v1
REFERENCE_MODEL=gpt-4o-mini

# --- Grey/white-box (HuggingFace, run on Colab / uni GPU server) ---
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
HF_TOKEN=mock-hf-token-change-me

# Which backend the CLI uses by default: mock | ollama | openai | hf
LOGSUB_BACKEND=mock
